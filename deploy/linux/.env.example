# deploy/linux/.env — 리눅스 PC에서 cp .env.example .env 후 수정

# PostgreSQL
POSTGRES_USER=freya
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=freya

# API
ODIN_API_PORT=8790
ALLOWED_ORIGINS=https://kk00701903-hub.github.io,http://localhost:8080,http://localhost:8081

# GitHub Pages PWA가 호출할 공개 URL (HTTPS 역프록시 뒤 주소)
# PUBLIC_API_URL=https://freya-api.yourdomain.com

# 저장소 마운트 (Claude Code 작업 디렉터리)
REPO_MOUNT=/home/user/freya

# Claude Code 브릿지 (호스트에서 node odin-api.mjs 실행 시 true 권장)
CLAUDE_BRIDGE_ENABLED=true
CLAUDE_WORKSPACE=/home/user/freya
CLAUDE_BIN=claude
CLAUDE_TIMEOUT_MS=120000
# ODIN_AI_API_KEY=your-secret-key-for-ai-endpoint

# 선택: Prometheus / WOL
# PROMETHEUS_URL=http://127.0.0.1:9090
# WOL_MAC=AA:BB:CC:DD:EE:FF
# WOL_BROADCAST=192.168.1.255
