# Odin — GitHub Pages 빌드 (로컬 .env는 gitignore)
# 프로덕션: GitHub Repository → Settings → Secrets → Actions 에 등록

# 통합 NAS/리눅스 API (권장 — chat/tasks/settings/wol/prometheus/ai)
# VITE_ODIN_API_URL=https://freya-api.example.com
# 설정 시 채팅은 자동으로 {VITE_ODIN_API_URL}/ai/chat (Claude Code) 사용

# n8n 웹훅 (Claude Code 대신 n8n 사용 시)
# VITE_N8N_WEBHOOK_URL=https://n8n.example.com/webhook/odin

# Claude /ai/chat API 키 (서버 ODIN_AI_API_KEY 와 동일, 선택)
# VITE_ODIN_AI_API_KEY=

# 개별 URL (레거시 — VITE_ODIN_API_URL 미설정 시)
# VITE_CHAT_ARCHIVE_URL=https://odin-api.example.com
# VITE_WOL_API_URL=https://odin-api.example.com
# VITE_PROMETHEUS_URL=https://odin-api.example.com/prometheus

# ── 리눅스 PC odin-api (deploy/linux/.env 참고) ──
# ODIN_API_PORT=8790
# ODIN_DATA_DIR=/var/lib/odin
# DATABASE_URL=postgresql://freya:PASSWORD@127.0.0.1:5432/freya
# ALLOWED_ORIGINS=https://kk00701903-hub.github.io,http://localhost:8080
# CLAUDE_BRIDGE_ENABLED=true
# CLAUDE_WORKSPACE=/home/user/freya
# CLAUDE_BIN=claude
# ODIN_AI_API_KEY=
# WOL_MAC=AA:BB:CC:DD:EE:FF
# WOL_BROADCAST=10.179.93.255
# PROMETHEUS_URL=http://127.0.0.1:9090
