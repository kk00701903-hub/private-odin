# Odin API — Nginx 역방향 프록시 예시 (HTTPS)
# VM101 / NAS에 배치 후 certbot 또는 NPM으로 SSL 적용

# /etc/nginx/sites-available/odin-api.conf

upstream odin_api {
    server 127.0.0.1:8790;
    keepalive 8;
}

server {
    listen 443 ssl http2;
    server_name odin-api.example.com;   # 실제 도메인으로 변경

    # ssl_certificate     /etc/letsencrypt/live/odin-api.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/odin-api.example.com/privkey.pem;

    # GitHub Pages PWA → NAS API (CORS는 odin-api.mjs ALLOWED_ORIGINS와 함께 설정)
    location / {
        proxy_pass http://odin_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prometheus 쿼리 등 장시간 요청
        proxy_read_timeout 60s;
    }
}

# HTTP → HTTPS 리다이렉트
server {
    listen 80;
    server_name odin-api.example.com;
    return 301 https://$host$request_uri;
}

# odin-api.mjs 환경 변수 예시:
# ALLOWED_ORIGINS=https://kk00701903-hub.github.io,https://odin.example.com
# DATABASE_URL=postgresql://odin:PASSWORD@127.0.0.1:5432/odin
